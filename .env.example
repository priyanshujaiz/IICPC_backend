# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=supersecretchangeme1234567890
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ─── Gateway ──────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─── Sandbox ──────────────────────────────────────────────────────────────────
SANDBOX_URL=http://localhost:3001
SANDBOX_PORT=3001

# ─── Kafka / Redpanda ─────────────────────────────────────────────────────────
# External (host machine dev) — Docker Compose overrides this to redpanda:9092 internally
KAFKA_BROKERS=localhost:19092

# ─── Redis ────────────────────────────────────────────────────────────────────
# Docker Compose overrides to redis://redis:6379 internally
REDIS_URL=redis://localhost:6379

# ─── TimescaleDB ──────────────────────────────────────────────────────────────
TIMESCALE_URL=postgres://postgres:postgres@localhost:5433/iicpc

# ─── MinIO (S3-compatible object store) ───────────────────────────────────────
# Docker Compose overrides MINIO_ENDPOINT to http://minio:9000 internally
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ─── Bot Fleet (Phase 2) ──────────────────────────────────────────────────────
# Bot Fleet
BOT_COUNT=5
BOT_LAMBDA=10
TELEMETRY_URL=http://localhost:4000
# Telemetry
TELEMETRY_PORT=4000

MAX_RUNTIME_MS=600000

# ─── Leaderboard (Phase 3) ────────────────────────────────────────────────────
LEADERBOARD_PORT=4001