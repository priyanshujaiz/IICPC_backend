# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=supersecretdev
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── Gateway ──────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173
# URL the gateway uses to trigger the sandbox pipeline
# local dev (tsx watch):  http://localhost:3001
# docker compose:         http://sandbox:3001  (set inline in compose, overrides this)
SANDBOX_URL=http://localhost:3001

# ─── Sandbox ──────────────────────────────────────────────────────────────────
SANDBOX_PORT=3001

# ─── Kafka / Redpanda ─────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:19092

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── TimescaleDB ──────────────────────────────────────────────────────────────
TIMESCALE_URL=postgresql://postgres:postgres@localhost:5433/iicpc

# ─── MinIO (S3-compatible object store) ───────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ─── Bot Fleet ────────────────────────────────────────────────────────────────
BOT_COUNT=50